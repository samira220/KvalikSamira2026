<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KvalikSamira.ViewModels"
             xmlns:models="using:KvalikSamira.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="KvalikSamira.Views.MasterView"
             x:DataType="vm:MasterViewModel">

    <ScrollViewer>
        <StackPanel Spacing="15" Margin="10">
            <TextBlock Text="Панель мастера" FontWeight="Bold" FontSize="20"/>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="15" CornerRadius="3">
                <StackPanel Spacing="5">
                    <TextBlock Text="{Binding MasterInfo}" FontSize="16"/>
                    <TextBlock Text="{Binding QualificationInfo}" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="15" CornerRadius="3">
                <StackPanel Spacing="5">
                    <TextBlock Text="Мои услуги" FontWeight="Bold" FontSize="16"/>
                    <ItemsControl ItemsSource="{Binding MyServices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Service">
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5" Margin="0,0,0,3">
                                    <TextBlock TextWrapping="Wrap">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} ({1}) — {2:F2} руб.">
                                                <Binding Path="name"/>
                                                <Binding Path="serviceType.name"/>
                                                <Binding Path="price"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="15" CornerRadius="3">
                <StackPanel Spacing="5">
                    <TextBlock Text="Записи клиентов" FontWeight="Bold" FontSize="16"/>
                    <ItemsControl ItemsSource="{Binding MyClients}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Appointment">
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5" Margin="0,0,0,3">
                                    <TextBlock TextWrapping="Wrap">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="Клиент: {0} {1} | Услуга: {2} | Очередь: #{3}">
                                                <Binding Path="user.lastName"/>
                                                <Binding Path="user.firstName"/>
                                                <Binding Path="service.name"/>
                                                <Binding Path="queueNumber"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="15" CornerRadius="3">
                <StackPanel Spacing="8">
                    <TextBlock Text="Заявка на повышение квалификации" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="Желаемый уровень:"/>
                    <ComboBox ItemsSource="{Binding QualificationLevels}"
                              SelectedItem="{Binding SelectedQualLevel}"
                              PlaceholderText="Выберите уровень" HorizontalAlignment="Stretch"/>
                    <Button Content="Отправить заявку" Command="{Binding RequestQualificationUpgradeCommand}"
                            HorizontalAlignment="Left" MinWidth="160"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
