<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KvalikSamira.ViewModels"
             xmlns:models="using:KvalikSamira.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="KvalikSamira.Views.ModeratorView"
             x:DataType="vm:ModeratorViewModel">

    <ScrollViewer>
        <StackPanel Spacing="15" Margin="10">
            <TextBlock Text="Панель модератора" FontWeight="Bold" FontSize="20"/>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="15" CornerRadius="3">
                <StackPanel Spacing="8">
                    <TextBlock Text="Привязка мастера к услуге" FontWeight="Bold" FontSize="16"/>

                    <TextBlock Text="Услуга:"/>
                    <ComboBox ItemsSource="{Binding ServicesList}"
                              SelectedItem="{Binding SelectedServiceMod}"
                              PlaceholderText="Выберите услугу" HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Service">
                                <TextBlock Text="{Binding name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Текущие мастера:"/>
                    <ItemsControl ItemsSource="{Binding CurrentMastersOfService}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Margin="5,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Мастер:"/>
                    <ComboBox ItemsSource="{Binding MastersList}"
                              SelectedItem="{Binding SelectedMasterMod}"
                              PlaceholderText="Выберите мастера" HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:User">
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1}">
                                            <Binding Path="lastName"/>
                                            <Binding Path="firstName"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Привязать" Command="{Binding BindMasterCommand}"/>
                        <Button Content="Отвязать" Command="{Binding UnbindMasterCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="15" CornerRadius="3">
                <StackPanel Spacing="8">
                    <TextBlock Text="Заявки на повышение квалификации" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="Нет заявок со статусом «На рассмотрении»."
                               Foreground="Gray" FontSize="12"
                               IsVisible="{Binding !HasPendingRequests}"/>
                    <ListBox ItemsSource="{Binding PendingRequests}" SelectedItem="{Binding SelectedRequest}" MaxHeight="200"
                             IsVisible="{Binding HasPendingRequests}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:QualificationRequest">
                                <TextBlock TextWrapping="Wrap">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1}: {2} → {3}">
                                            <Binding Path="user.lastName"/>
                                            <Binding Path="user.firstName"/>
                                            <Binding Path="currentLevel"/>
                                            <Binding Path="requestedLevel"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Одобрить" Command="{Binding ApproveRequestCommand}"/>
                        <Button Content="Отклонить" Command="{Binding RejectRequestCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
